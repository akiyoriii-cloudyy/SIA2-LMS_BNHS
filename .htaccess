<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On
    RewriteBase /LMS_BNHS/

    # Handle Authorization Header (for Bearer tokens on /api/*)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Allow direct access to /public/*
    RewriteRule ^public(/|$) - [L]

    # Don't rewrite the front controller itself.
    RewriteRule ^index\.php(/|$) - [L]

    # Serve existing files/directories from /public without showing /public in the URL.
    RewriteCond %{DOCUMENT_ROOT}/LMS_BNHS/public/$1 -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/LMS_BNHS/public/$1 -d
    RewriteRule ^(.+)$ public/$1 [L]

    # Otherwise, send requests to the root front controller (which boots Laravel from /public).
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ index.php/$1 [L,QSA]
</IfModule>

# Performance + security headers (safe defaults for XAMPP/Apache)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType application/font-woff2 "access plus 30 days"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/css application/javascript text/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>
